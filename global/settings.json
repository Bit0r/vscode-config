{
	// Self
	"update.mode": "manual",
	"update.showReleaseNotes": false,
	"workbench.enableExperiments": false,
	"vsicons.dontShowNewVersionMessage": true,
	"http.electronFetch": true,
	"http.fetchAdditionalSupport": false,
	"http.systemCertificatesNode": true,
	// Window
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.incrementalNaming": "smart",
	"window.restoreWindows": "none",
	"window.customMenuBarAltFocus": false,
	"window.enableMenuBarMnemonics": false,
	// "window.titleBarStyle": "custom",
	// "window.dialogStyle": "custom",
	"workbench.colorTheme": "Dark+",
	"workbench.iconTheme": "vscode-icons",
	"workbench.activityBar.location": "top",
	"workbench.quickOpen.closeOnFocusLost": false,
	"workbench.list.smoothScrolling": true,
	"security.workspace.trust.untrustedFiles": "open",
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.confirmPasteNative": false,
	// "window.zoomLevel": 0.4,
	// Editor
	"editor.lineNumbers": "on",
	"editor.glyphMargin": true,
	"search.showLineNumbers": true,
	"editor.tabSize": 2,
	"editor.fontSize": 20,
	//"editor.fontLigatures": true,
	// [NOTE]: 如果设置不当，会导致渲染错误，https://github.com/microsoft/vscode/issues/258080#issuecomment-3146042255
	"editor.fontLigatures": "'calt', 'cv01', 'cv03', 'cv08', 'cv61', 'cv62', 'cv41', 'ss03', 'ss07', 'ss08', 'ss11'",
	"editor.fontFamily": "Maple Mono NF, Fira Code Light, Noto Sans Mono CJK SC Light, monospace",
	"editor.renderWhitespace": "boundary",
	"editor.renderControlCharacters": true,
	"editor.smoothScrolling": true,
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.linkedEditing": true,
	"editor.stickyScroll.enabled": false,
	"editor.largeFileOptimizations": false,
	"editor.guides.bracketPairs": "active",
	"editor.inlineSuggest.showToolbar": "always",
	// "editor.experimentalWhitespaceRendering": "font",
	"editor.suggest.snippetsPreventQuickSuggestions": false,
	"editor.bracketPairColorization.independentColorPoolPerBracketType": true,
	"editor.experimental.treeSitterTelemetry": true,
	"editor.codeActionsOnSave": {
		"source.organizeImports": "explicit",
	},
	"diffEditor.codeLens": true,
	"diffEditor.ignoreTrimWhitespace": true,
	"diffEditor.experimental.showMoves": true,
	"diffEditor.experimental.useTrueInlineView": true,
	"workbench.editor.tabSizing": "shrink",
	"workbench.editor.wrapTabs": true,
	"workbench.editor.enablePreview": false,
	"workbench.editor.highlightModifiedTabs": true,
	"interactiveWindow.promptToSaveOnClose": true,
	"interactiveWindow.executeWithShiftEnter": true,
	"workbench.editorAssociations": {
		"*.copilotmd": "vscode.markdown.preview.editor",
		"*.ipynb": "jupyter-notebook",
		"{git,gitlens}:/**/*.{md,csv,svg}": "default",
	},
	"cunneen-copy-breadcrumbs.separationString": ".",
	// Files
	"files.exclude": {
		"**/.oxen": true,
		"**/wandb": true
	},
	"search.exclude": {
		"**/.vscode/": true,
		"**/tsconfig*": true
	},
	"files.watcherExclude": {
		"**/composer.lock": true,
		"**/dist/**": true,
		"**/pnpm-lock.yaml": true,
		"**/polyfill*": true,
		"**/vendor/**": true,
		"**/yarn.lock": true,
		"**/*.class": true
	},
	"files.associations": {
		"*.dbclient-js": "javascript",
		"*.ssv": "csv (whitespace)",
		"*.psv": "csv (pipe)",
		"*.usv": "dynamic csv",
		"*.ddb": "json",
		"*.cnf": "properties",
		"*rc": "properties",
		"*config": "properties",
		"*ignore": "ignore",
		"**/.ssh/config": "ssh_config",
		"*ssh*": "ssh_config",
		".env*": "dotenv",
		".dev.vars*": "dotenv",
		"*.fish": "fish"
	},
	// Format
	"files.eol": "\n",
	"files.autoSave": "onFocusChange",
	"editor.insertSpaces": false,
	"editor.formatOnSave": true,
	//"editor.defaultFormatter": "dprint.dprint",
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,
	//"notebook.formatOnSave.enabled": true,
	"notebook.formatOnCellExecution": true,
	"dprint.verbose": true,
	"dprint.experimentalLsp": true,
	// Terminal
	"debug.console.fontSize": 20,
	"debug.terminal.clearBeforeReusing": true,
	"terminal.integrated.shellIntegration.enabled": false,
	"terminal.integrated.shellIntegration.history": 10000,
	"terminal.integrated.fontSize": 20,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.smoothScrolling": true,
	"terminal.integrated.allowChords": false,
	"terminal.integrated.sendKeybindingsToShell": true,
	"terminal.integrated.inheritEnv": false,
	"terminal.integrated.enablePersistentSessions": false,
	"terminal.integrated.suggest.enabled": true,
	"terminal.integrated.persistentSessionReviveProcess": "never",
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	"terminal.integrated.enableVisualBell": true,
	"terminal.integrated.enableKittyKeyboardProtocol": false,
	"terminal.integrated.customGlyphs": false,
	"terminal.integrated.textBlinking": true,
	"terminal.integrated.confirmOnExit": "hasChildProcesses",
	"terminal.integrated.enableImages": true,
	"terminal.integrated.gpuAcceleration": "off",
	"terminal.integrated.suggest.providers": {
		"lsp": true
	},
	"terminal.integrated.localEchoExcludePrograms": [
		"vim",
		"vi",
		"nano",
		"tmux",
		"micro",
		"editor",
		"fresh"
	],
	// Outline Map
	"editor.minimap.enabled": false,
	"outline-map.follow": "viewport",
	// Bookmarks
	"bookmarks.saveBookmarksInProject": true,
	"bookmarks.useWorkaroundForFormatters": true,
	// VCS
	"git.enableSmartCommit": true,
	"git.untrackedChanges": "separate",
	"git.terminalGitEditor": true,
	"conventionalCommits.autoCommit": false,
	"conventionalCommits.emojiFormat": "emoji",
	"[ignore][nuxtignore]": {
		"editor.formatOnSave": false,
	},
	// Easy CodeSnap
	"easy-codesnap.containerPadding": "0",
	"easy-codesnap.showWindowControls": false,
	"easy-codesnap.windowStyle": "windows",
	"easy-codesnap.target": "window",
	"easy-codesnap.showLineNumbers": false,
	"easy-codesnap.enableResizing": false,
	"easy-codesnap.saveScale": 4,
	// CSV
	"[dynamic csv]": {},
	"[csv][dynamic csv][tsv][csv (semicolon)][csv (whitespace)]": {
		"editor.inlayHints.maximumLength": 0,
		"editor.stickyScroll.enabled": true,
		"editor.defaultFormatter": "mechatroner.rainbow-csv",
	},
	"rainbow_csv.rbql_with_headers_by_default": true,
	"rainbow_csv.enable_context_menu_head": true,
	"rainbow_csv.enable_context_menu_tail": true,
	// rsync
	"sync-rsync.onSaveIndividual": true,
	//"sync-rsync.shell": "sshpass -f ~/.ssh/vm.pass ssh vm",
	"sync-rsync.exclude": [
		".git",
		".svn"
	],
	// Remote
	"remote.autoForwardPorts": false,
	"remote.autoForwardPortsSource": "process",
	"remote.SSH.lockfilesInTmp": true,
	//"remote.SSH.showLoginTerminal": true,
	"remote.SSH.useLocalServer": false,
	//"remote.SSH.remoteServerListenOnSocket": true, // 打开此项可以提高安全性，但是可能会导致autodl连接失败
	"remote.SSH.enableX11Forwarding": false,
	"remote.downloadExtensionsLocally": true, // 本地下载扩展，避免网络问题
	"remote.SSH.localServerDownload": "always", // 本地下载服务器，避免网络问题，但有 bug: https://github.com/microsoft/vscode-remote-release/issues/9246
	"remote.SSH.remotePlatform": {
		"*": "linux",
		"zw403-*": "linux",
		"autodl-*": "linux",
		"zw403-1080ti": "linux",
		"autodl-a40": "linux",
		"autodl-a40-earth": "linux",
		"zw403-3060-zw403": "linux",
		"zw403-3060-bit0r": "linux",
		"autodl-vGPU": "linux",
		"zw403-1080ti-bit0r": "linux",
		"autodl-CPU": "linux",
		"autodl-vGPU-2": "linux",
		"vastai-a40": "linux"
	},
	// fish
	"[fish]": {
		"editor.tabSize": 4,
		"editor.insertSpaces": true,
		"editor.detectIndentation": false,
		"editor.defaultFormatter": "bmalehorn.vscode-fish",
	},
	// regex
	"reg-visualizer.hide-footer": true,
	"reg-visualizer.hide-fork": true,
	"reg-visualizer.hide-header": true,
	// HTML/CSS/SCSS
	"html.format.wrapLineLength": 60,
	"html.format.templating": true,
	"html.format.indentHandlebars": true,
	"emmet.showSuggestionsAsSnippets": true,
	"open-php-html-js-in-browser.customBrowserPath": "/usr/bin/vivaldi",
	"open-php-html-js-in-browser.selectedBrowser": "Custom...",
	"css.lint.duplicateProperties": "warning",
	"css.lint.ieHack": "warning",
	"css.lint.importStatement": "warning",
	"css.lint.unknownVendorSpecificProperties": "warning",
	"scss.lint.duplicateProperties": "warning",
	"scss.lint.ieHack": "warning",
	"scss.lint.unknownVendorSpecificProperties": "warning",
	"tailwindCSS.showPixelEquivalents": false,
	"tailwindCSS.classAttributes": [
		"class",
		"className",
		"ngClass",
		"class:list",
		"ui"
	],
	// Emmet
	"emmet.variables": {
		"lang": "zh-CN"
	},
	"emmet.extensionsPath": [
		"./.vscode/emmet/"
	],
	"emmet.includeLanguages": {
		"svelte": "html",
		//"vue": "html",
	},
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features",
	},
	// Vue
	"npm.packageManager": "pnpm",
	"js/ts.format.semicolons": "remove",
	"js/ts.preferences.quoteStyle": "single",
	"js/ts.format.indentSwitchCase": false,
	"js/ts.updateImportsOnFileMove.enabled": "never",
	"vue.autoInsert.dotValue": true,
	"vue.codeActions.enabled": false,
	"vue.codeActions.askNewComponentName": false,
	"vue.format.template.initialIndent": false,
	"vue.splitEditors.icon": true,
	"vue.updateImportsOnFileMove.enabled": false,
	"vue.server.hybridMode": "typeScriptPluginOnly",
	"oxc.path.oxfmt": "/home/bit0r/.local/bin/oxfmt",
	"oxc.path.oxlint": "/home/bit0r/.local/bin/oxlint",
	"oxc.trace.server": "messages",
	"oxc.lint.run": "onSave",
	"[javascript][typescript]": {
		"editor.defaultFormatter": "oxc.oxc-vscode",
	},
	"[vue]": {
		"editor.defaultFormatter": "Vue.volar"
	},
	"i18n-ally.keystyle": "nested",
	"i18n-ally.sortCompare": "locale",
	"i18n-ally.enabledParsers": [
		"yaml"
	],
	"i18n-ally.enabledFrameworks": [
		"vue",
		"vue-sfc"
	],
	// Nuxt
	"nuxtr.piniaFiles.defaultTemplate": "setup",
	"nuxtr.vueFiles.style.alwaysScoped": true,
	"nuxtr.vueFiles.style.defaultLanguage": "scss",
	// Deno
	"deno.internalDebug": true,
	"deno.codeLens.references": true,
	"deno.codeLens.implementations": true,
	"deno.codeLens.referencesAllFunctions": true,
	"deno.codeLens.test": true,
	// Docker
	"[dockercompose]": {
		"editor.defaultFormatter": "ms-azuretools.vscode-docker",
		"AkiraVoid.formatWithCLI.command": "yamlfix '{file}' && cat '{file}'"
	},
	// Markdown
	"markdown.preview.fontSize": 20,
	"markdown.extension.completion.enabled": true,
	"markdown.extension.print.absoluteImgPath": false,
	"markdown.extension.tableFormatter.normalizeIndentation": true,
	"markdown.extension.toc.orderedList": true,
	"pandoc.docker.enabled": false,
	"pandoc.docxOptString": "-d pandoc",
	"pandoc.htmlOptString": "-d pandoc",
	"pandoc.pdfOptString": "-d pandoc",
	"pandoc.render.openViewer": false,
	"[plaintext]": {
		"editor.formatOnSave": false,
	},
	"[markdown][plaintext]": {
		"editor.defaultFormatter": "darkriszty.markdown-table-prettify",
		"vscode-hanzi-counter.template.tooltipTemplateName": "zh-hans",
	},
	"markdown.extension.list.toggle.candidate-markers": [
		"-",
		"1.",
	],
	// D2
	"D2.previewLayout": "tala",
	"[d2]": {
		"editor.defaultFormatter": "Terrastruct.d2"
	},
	// Typst
	"typst-lsp.exportPdf": "never",
	// SystemD
	"[systemd-conf]": {
		"editor.defaultFormatter": "hangxingliu.vscode-systemd-support"
	},
	// Caddyfile
	"[caddyfile]": {
		"editor.defaultFormatter": "matthewpi.caddyfile-support",
	},
	// properties
	"[properties][ssh_config]": {
		// 没有一个通用的 properties 格式化工具，所以这里不设置保存时格式化
		"editor.formatOnSave": false,
		"editor.defaultFormatter": "AkiraVoid.format-with-cli",
		"AkiraVoid.formatWithCLI.command": "cfg-format '{file}'",
	},
	// Dotenv
	"dotenv.enableAutocloaking": false,
	// json
	"[json][jsonc][jsonl]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	// yaml
	"redhat.telemetry.enabled": true,
	"yaml.format.singleQuote": true,
	"yaml.format.enable": false,
	"[yaml][github-actions-workflow]": {
		"editor.tabSize": 2,
		"editor.insertSpaces": true,
		"editor.detectIndentation": false,
		"editor.defaultFormatter": "AkiraVoid.format-with-cli",
		"AkiraVoid.formatWithCLI.command": "yamlfix '{file}' && cat '{file}'",
	},
